# Enhanced Sehat-Saathi Configuration
# Add these environment variables to enable external healthcare API integrations

# Lybrate Integration
LYBRATE_API_KEY=your_lybrate_api_key_here
LYBRATE_PARTNER_ID=your_lybrate_partner_id

# Practo Integration  
PRACTO_API_KEY=your_practo_api_key_here
PRACTO_CLIENT_ID=your_practo_client_id

# Enhanced Features Configuration
ENABLE_EXTERNAL_DOCTOR_SEARCH=true
ENABLE_LAB_TESTS_BOOKING=true
ENABLE_HEALTH_RECORDS_SYNC=true
ENABLE_PRESCRIPTION_MANAGEMENT=true

# Rate Limiting for External APIs
MAX_API_CALLS_PER_MINUTE=60
API_CACHE_DURATION_MINUTES=15

# Webhook URLs for booking confirmations
LYBRATE_WEBHOOK_URL=https://your-sehat-saathi.com/webhooks/lybrate
PRACTO_WEBHOOK_URL=https://your-sehat-saathi.com/webhooks/practo